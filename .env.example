# Supabase — from Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. NEVER expose to the client. From Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenAI — from https://platform.openai.com/api-keys. Used for Whisper (speech-to-text).
OPENAI_API_KEY=

# Resend — from https://resend.com/api-keys. Used to email the tradesperson when a
# customer signs their quote.
RESEND_API_KEY=

# Used to build the magic-link redirect URL. Set to your Vercel/production URL in prod.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe — SaaS subscription billing (T3 / financial). ALWAYS use TEST MODE keys
# here and in Vercel preview/dev environments (test secret keys start with
# `sk_test_`). See docs/MANUAL-STEPS-PENDING.md for how to create these.
# From Developers → API keys (test mode).
STRIPE_SECRET_KEY=
# From Developers → Webhooks → your endpoint → Signing secret (starts with whsec_).
STRIPE_WEBHOOK_SECRET=
# The Price ID (starts with price_) for the €29/month recurring plan.
STRIPE_PRICE_ID=
# Not used server-side yet (Checkout is hosted, not Elements) -- documented for
# future use if custom Elements-based payment UI is ever added.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
